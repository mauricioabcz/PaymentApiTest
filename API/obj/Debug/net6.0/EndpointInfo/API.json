              "schema": {
                "$ref": "#/components/schemas/BancoCreateDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "get": {
        "tags": [
          "Bancos"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
